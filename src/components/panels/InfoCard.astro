            <path d="M8.985 2.596v17.548l3.915 1.261V6.688c0-.69.304-1.151.794-.991.636.181.76.814.76 1.505v5.876c2.441 1.193 4.362-.002 4.362-3.153 0-3.236-1.536-4.843-5.916-6.305-1.202-.399-2.587-.726-3.915-1.024zM2 17.116c-.003 1.005.343 1.689 1.237 2.108 1.778.834 4.744.692 7.164-.203V17.03l-3.593 1.322c-1.327.49-1.534-.044-1.534-.044-.207-.448.134-.88 1.534-1.432l3.593-1.446v-2.136l-5.005 2.059s-2.212.832-3.156 1.313c-.377.192-.24.45-.24.45zm17.118 2.222c1.49-.634 1.807-1.6 1.067-2.21-.692-.567-1.959-.823-3.656-.824h-.003l-4.625.016v1.993l3.228-1.169s1.606-.583 2.673.004c1.003.553-.107 1.212-.107 1.212l-5.793 2.39v2.078z"/>
          </svg>
          <span class="text-[11px] font-medium text-text-muted">PlayStation</span>
        </div>
      </Card>
    </a>
    <a href="https://www.nintendo.com/us/store/products/hack-g-u-last-recode-switch/" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex flex-col items-center gap-1.5 py-1">
          <svg class="w-5 h-5 text-text-muted" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.176 24h3.674c3.376 0 6.15-2.774 6.15-6.15V6.15C24 2.775 21.226 0 17.85 0H14.176c-.094 0-.17.076-.17.17v23.66c0 .094.076.17.17.17zm3.674-20.293a2.446 2.446 0 0 1 2.443 2.443 2.446 2.446 0 0 1-2.443 2.443 2.446 2.446 0 0 1-2.442-2.443 2.446 2.446 0 0 1 2.442-2.443zM6.15 0h3.674c.094 0 .17.076.17.17v23.66c0 .094-.076.17-.17.17H6.15C2.775 24 0 21.226 0 17.85V6.15C0 2.774 2.775 0 6.15 0zm0 15.707a2.446 2.446 0 0 0-2.443 2.443A2.446 2.446 0 0 0 6.15 20.593a2.446 2.446 0 0 0 2.443-2.443 2.446 2.446 0 0 0-2.443-2.443z"/>
          </svg>
          <span class="text-[11px] font-medium text-text-muted">Switch</span>
        </div>
      </Card>
    </a>
  </div>

  <!-- Links -->
  <h3 class="font-display text-xs font-semibold tracking-wider uppercase text-text-dim mb-2 flex items-center gap-2">
    <span class="w-3 h-0.5 bg-accent"></span>
    Links
  </h3>
  <div class="space-y-2">
    <a href="https://www.cc2.co.jp/hackzero/en/" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex items-center gap-3">
          <div class="shrink-0 w-8 h-8 rounded-md bg-panel-light flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M2 12h20"></path>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-text">.hack//ZERO</p>
            <p class="text-[10px] text-text-dim">Official project site</p>
          </div>
          <svg class="w-3.5 h-3.5 text-text-dim ml-auto shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </div>
      </Card>
    </a>
    <a href="https://www.cc2.co.jp/cc2store/" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex items-center gap-3">
          <div class="shrink-0 w-8 h-8 rounded-md bg-panel-light flex items-center justify-center">
