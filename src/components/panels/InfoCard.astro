---
import Card from '../Card.astro';
---

<!-- Sub-view: Group Info (default) -->
<div id="view-group" class="subview">
  <div class="text-center mb-6 pt-2">
    <div class="w-14 h-14 mx-auto mb-3 relative">
      <div class="absolute inset-0 hex-clip bg-text flex items-center justify-center">
        <svg class="w-6 h-6 text-bg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
          <polygon points="12 6 18 9.5 18 14.5 12 18 6 14.5 6 9.5 12 6"></polygon>
        </svg>
      </div>
    </div>
    <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight mb-2 text-text">
      Dot Hackers
    </h1>
    <p class="text-sm text-text-dim font-mono tracking-wider uppercase">VRChat Community</p>
  </div>

  <p class="text-sm text-text-muted text-center leading-relaxed max-w-lg mx-auto mb-6">
    A community for fans of the .hack&#47;&#47; series. We curate a database of .hack-themed
    VRChat worlds and avatars, host community meetups and watch parties, and bring fans together to experience
    「The World」 in virtual reality.
  </p>

  <div class="flex items-center justify-center gap-3 pt-3 border-t border-panel-border">
    <a href="https://discord.gg/2PwUyaKbfR" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent-bright transition-all duration-300">
      Join Discord
    </a>
    <a href="https://vrc.group/HACK.2861" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg glass glass-hover text-text-muted font-medium text-sm hover:text-text transition-all duration-300">
      VRChat Group
    </a>
  </div>
</div>

<!-- Sub-view: What is .hack? -->
<div id="view-whatis" class="subview" style="display: none;">
  <div class="space-y-4">
    <p class="text-sm text-text-muted leading-relaxed text-center">
      <strong class="text-text">.hack</strong> (pronounced "dot hack") is a multimedia franchise
      depicting a virtual game called <em class="text-accent">「The World」</em> and the players
      swept up in its mysteries. Debuting in 2002 with the anime .hack//Sign and the PS2 game
      .hack//Infection, the series spans action RPGs, anime, novels, manga, and OVAs — pioneering
      cross-media storytelling by weaving interconnected stories across different formats within the
      same universe.
    </p>

    <!-- Interactive Timeline -->
    <div class="timeline-container">
      <div class="timeline-track" role="tablist">
        <button class="timeline-node" role="tab" data-entry="sign">.hack//Sign</button>
        <button class="timeline-node" role="tab" data-entry="imoq">.hack//IMOQ</button>
        <button class="timeline-node" role="tab" data-entry="roots">.hack//Roots</button>
        <button class="timeline-node" role="tab" data-entry="gu">.hack//G.U.</button>
        <button class="timeline-node" role="tab" data-entry="link">.hack//Link</button>
        <button class="timeline-node" role="tab" data-entry="quantum">.hack//Quantum</button>
        <button class="timeline-node" role="tab" data-entry="movie">Beyond the World</button>
      </div>

      <!-- Expandable details -->
      <div class="timeline-details">
        <div class="timeline-detail" id="entry-sign" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/sign-1.webp" alt=".hack//Sign" class="gallery-active">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">Anime</span>
              <span class="timeline-type-detail">2002 · 26 episodes</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                A player named Tsukasa awakens inside 「The World」 with no memory and discovers he cannot log out.
                As others are drawn into the mystery surrounding him, they begin to uncover secrets hidden
                within the game itself.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">AI Buster (novel) · Legend of the Twilight (manga/anime) · ZERO (novel) · Unison (OVA)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline-detail" id="entry-imoq" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/imoq-1.webp" alt=".hack//Infection" class="gallery-active">
              <img src="/images/timeline/imoq-2.webp" alt=".hack//Mutation">
              <img src="/images/timeline/imoq-3.webp" alt=".hack//Outbreak">
              <img src="/images/timeline/imoq-4.webp" alt=".hack//Quarantine">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">RPG</span>
              <span class="timeline-type-detail">2002–2003 · 4 games (PS2)</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                When his friend falls into a coma after a strange encounter in 「The World」, a new player named
                Kite obtains a mysterious power and sets out to uncover the truth - both inside and outside the
                game. The four games (Infection, Mutation, Outbreak, Quarantine) tell one continuous story.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">Liminality (OVA) · Another Birth (novels) · XXXX (manga) · Epitaph of Twilight (light novel)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline-detail" id="entry-roots" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/roots-1.webp" alt=".hack//Roots" class="gallery-active">
              <img src="/images/timeline/roots-2.jpg" alt=".hack//Roots">
              <img src="/images/timeline/roots-3.webp" alt=".hack//Roots">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">Anime</span>
              <span class="timeline-type-detail">2006 · 26 episodes</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                A prelude to G.U., following a player named Haseo during his early days in the rebuilt version
                of 「The World」. After losing everything to a mysterious player killer, he sets out on a path of
                revenge that leads him deeper into the game's hidden conflicts.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">CELL (novel) · Returner (OVA) · Alcor (manga)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline-detail" id="entry-gu" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/gu-1.webp" alt=".hack//G.U." class="gallery-active">
              <img src="/images/timeline/gu-2.webp" alt=".hack//G.U.">
              <img src="/images/timeline/gu-3.webp" alt=".hack//G.U.">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">RPG</span>
              <span class="timeline-type-detail">2006–2007 · 3 games + Vol.4 (PS2 / PS4 / PC)</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                Haseo, now known as "The Terror of Death," hunts a powerful player killer called Tri-Edge who
                is responsible for putting players into comas. Across three volumes, his quest for revenge
                evolves into something much larger as he uncovers the truth behind 「The World」 R:2. 
                Available today as .hack//G.U. Last Recode.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">G.U.+ (manga) · G.U. Novels · Trilogy (CGI film)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline-detail" id="entry-link" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/link-1.jpg" alt=".hack//Link" class="gallery-active">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">RPG</span>
              <span class="timeline-type-detail">2010 · PSP</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                High schooler Tokio Kuryuu is dragged into 「The World」 by a mysterious program and gains
                the ability to travel through its history. Reliving key events across every era of the
                franchise, he teams up with characters from Sign through G.U. to confront a threat that
                spans the entire timeline of 「The World」.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">Twilight Knights (manga)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline-detail" id="entry-quantum" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/quantum-1.jpg" alt=".hack//Quantum" class="gallery-active">
              <img src="/images/timeline/quantum-2.jpg" alt=".hack//Quantum">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">OVA</span>
              <span class="timeline-type-detail">2010–2011 · 3 episodes</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                Sakuya, Tobias, and Mary are three close friends playing the latest revision of
                「The World」. When a routine adventure goes wrong and they stumble into a sealed area,
                one of them is left comatose in the real world - pulling the others into a desperate
                investigation that uncovers a new threat lurking within the game.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">Quantum+ (manga) · Quantum I (manga)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="timeline-detail" id="entry-movie" role="tabpanel">
          <div class="timeline-detail-layout">
            <div class="timeline-gallery" data-gallery>
              <img src="/images/timeline/btw-1.webp" alt=".hack//Beyond the World" class="gallery-active">
              <img src="/images/timeline/btw-2.jpg" alt=".hack//Beyond the World">
              <img src="/images/timeline/btw-3.webp" alt=".hack//Beyond the World">
              <div class="timeline-gallery-dots">
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
                <span class="timeline-gallery-dot"></span>
              </div>
            </div>
            <div class="timeline-detail-content">
              <span class="timeline-type">Film</span>
              <span class="timeline-type-detail">2012</span>
              <p class="text-sm text-text-muted leading-relaxed mt-2">
                In 2024, a girl named Sora who has never played an online game joins the latest version of
                「The World」. She quickly discovers something is deeply wrong; a mysterious phenomenon is causing
                the game to bleed into reality, and she may be the only one who can stop it.
              </p>
              <div class="timeline-related">
                <span class="timeline-related-label">Related media</span>
                <span class="timeline-related-items">Versus (PS3 game)</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

