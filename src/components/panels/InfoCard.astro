---
import Card from '../Card.astro';
---

<!-- Sub-view: Group Info (default) -->
<div id="view-group" class="subview">
  <div class="text-center mb-6 pt-2">
    <div class="w-14 h-14 mx-auto mb-3 relative">
      <div class="absolute inset-0 hex-clip bg-text flex items-center justify-center">
        <svg class="w-6 h-6 text-bg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
          <polygon points="12 6 18 9.5 18 14.5 12 18 6 14.5 6 9.5 12 6"></polygon>
        </svg>
      </div>
    </div>
    <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight mb-2 text-text">
      Dot Hackers
    </h1>
    <p class="text-sm text-text-dim font-mono tracking-wider uppercase">VRChat Community</p>
  </div>

  <p class="text-base text-text-muted text-center leading-relaxed max-w-lg mx-auto mb-6">
    We're a VRChat community built around a shared love for the .hack franchise. We maintain a
    database of .hack-themed worlds, organize group explorations, and serve as a hub for fans
    who want to experience The World in virtual reality.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 mb-6">
    <Card>
      <div class="text-accent mb-1.5">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20"></path>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-text mb-0.5">World Curation</h3>
      <p class="text-xs text-text-dim leading-relaxed">Find and explore .hack VRChat worlds.</p>
    </Card>

    <Card>
      <div class="text-text-muted mb-1.5">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-text mb-0.5">Group Sessions</h3>
      <p class="text-xs text-text-dim leading-relaxed">Regular meetups and explorations.</p>
    </Card>

    <Card>
      <div class="text-text-muted mb-1.5">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-text mb-0.5">Avatar Showcase</h3>
      <p class="text-xs text-text-dim leading-relaxed">.hack character avatars in VRChat.</p>
    </Card>

    <Card>
      <div class="text-accent-dim mb-1.5">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
      </div>
      <h3 class="text-sm font-semibold text-text mb-0.5">Instance Tracker</h3>
      <p class="text-xs text-text-dim leading-relaxed">ALGOS bot monitors active instances.</p>
    </Card>
  </div>

  <div class="flex items-center justify-center gap-3 pt-3 border-t border-panel-border">
    <a href="https://discord.gg/2PwUyaKbfR" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent-bright transition-all duration-300">
      Join Discord
    </a>
    <a href="https://vrc.group/HACK.2861" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg glass glass-hover text-text-muted font-medium text-sm hover:text-text transition-all duration-300">
      VRChat Group
    </a>
  </div>
</div>

<!-- Sub-view: What is .hack? -->
<div id="view-whatis" class="subview" style="display: none;">
  <Card hover={false}>
    <h3 class="font-display text-base font-semibold text-text mb-3 flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-accent"></span>
      What is .hack?
    </h3>
    <div class="space-y-3 text-base text-text-muted leading-relaxed">
      <p>
        <strong class="text-text">.hack</strong> (pronounced "dot hack") is a multimedia franchise
        created by CyberConnect2 and published by Bandai Namco. It spans anime series, manga, novels,
        and video games — all set in or around a fictional MMORPG called <em class="text-accent">The World</em>.
      </p>
      <p>
        The franchise explores themes of virtual reality, digital consciousness, and the blurring line
        between online and offline identities — themes that resonate deeply with the VRChat community.
      </p>
      <p>
        Major entries include <em class="text-text">.hack//Sign</em> (anime),
        <em class="text-text">.hack//IMOQ</em> (PS2 games),
        <em class="text-text">.hack//G.U.</em> (PS2/PS4/PC games),
        and <em class="text-text">.hack//Roots</em> (anime).
      </p>
    </div>
  </Card>
</div>

<!-- Sub-view: Official -->
<div id="view-official" class="subview" style="display: none;">

  <!-- Social -->
  <h3 class="font-display text-xs font-semibold tracking-wider uppercase text-text-dim mb-2 flex items-center gap-2">
    <span class="w-3 h-0.5 bg-accent"></span>
    Social
  </h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-5">
    <a href="https://x.com/dothack_cc2" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-text-muted shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-text truncate">@dothack_cc2</p>
            <p class="text-[10px] text-text-dim truncate">CC2 .hack</p>
          </div>
        </div>
      </Card>
    </a>
    <a href="https://x.com/dothackofficial" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-text-muted shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-text truncate">@dothackofficial</p>
            <p class="text-[10px] text-text-dim truncate">Official</p>
          </div>
        </div>
      </Card>
    </a>
  </div>

  <!-- Games -->
  <h3 class="font-display text-xs font-semibold tracking-wider uppercase text-text-dim mb-2 flex items-center gap-2">
    <span class="w-3 h-0.5 bg-accent"></span>
    .hack//G.U. Last Recode
  </h3>
  <div class="grid grid-cols-3 gap-2 mb-5">
    <a href="https://store.steampowered.com/app/525480/hackGU_Last_Recode/" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex flex-col items-center gap-1.5 py-1">
          <svg class="w-5 h-5 text-text-muted" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z"/>
          </svg>
          <span class="text-[11px] font-medium text-text-muted">Steam</span>
        </div>
      </Card>
    </a>
    <a href="https://store.playstation.com/en-us/product/UP0700-CUSA07559_00-HACKGURECODE0000/" target="_blank" rel="noopener noreferrer" class="block">
      <Card>
        <div class="flex flex-col items-center gap-1.5 py-1">
