---
interface Props {
  href?: string;
  class?: string;
  hover?: boolean;
}

const { href, class: className = '', hover = true } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  target={href ? '_blank' : undefined}
  rel={href ? 'noopener noreferrer' : undefined}
  class:list={[
    'block rounded-xl glass p-4 transition-all duration-300',
    hover && 'hover:bg-white/5 hover:border-white/10 hover:-translate-y-0.5',
    href && 'cursor-pointer',
    className,
  ]}
>
  <slot />
</Tag>
