---
// Main card wrapper — the "hack" part of .hack//
interface Props {
  id: string;
  title: string;
  accent?: string;
}

const { id, title } = Astro.props;
---

<div id={id} class="main-card" data-card-role="main">
  <div class="main-card-inner">
    <!-- Title bar with sub-view navigation -->
    <div class="main-card-titlebar">
      <div class="hex-badge bg-text">
        <svg class="w-3 h-3 text-bg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
          <polygon points="12 6 18 9.5 18 14.5 12 18 6 14.5 6 9.5 12 6"></polygon>
        </svg>
      </div>
      <h2 class="font-display text-sm font-semibold tracking-wider text-text-muted">
        {title}
      </h2>
      <div class="subview-nav ml-auto">
        <slot name="nav" />
      </div>
    </div>

    <!-- Content -->
    <div class="main-card-content">
      <slot />
    </div>
  </div>
</div>
