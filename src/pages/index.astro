---
import DesktopLayout from '../layouts/DesktopLayout.astro';
import DesktopShell from '../components/desktop/DesktopShell.astro';
import GlossyCard from '../components/desktop/GlossyCard.astro';
import SlashCard from '../components/desktop/SlashCard.astro';
import InfoCard from '../components/panels/InfoCard.astro';
import DatabaseCard from '../components/panels/DatabaseCard.astro';
import CommunityPanel from '../components/panels/CommunityPanel.astro';
import { getCollection } from 'astro:content';

const worlds = await getCollection('worlds');
const avatars = await getCollection('avatars');

// Sort by VRC dates: publishedAt with a temporary boost from updatedAt
// that decays over ~6 months back to the publish position.
// Falls back to addedDate if VRC dates aren't populated yet.
const DECAY_MS = 6 * 30 * 24 * 60 * 60 * 1000; // ~6 months
const now = Date.now();

function parseDate(value: string | undefined): number | null {
  if (!value || value === 'none') return null;
  const ms = new Date(value).getTime();
  return Number.isNaN(ms) ? null : ms;
}

function getEffectiveDate(world: typeof worlds[number]): number {
  const created = parseDate(world.data.publishedAt)
    ?? parseDate(world.data.updatedAt)
    ?? new Date(world.data.addedDate).getTime();
  const updated = parseDate(world.data.updatedAt) ?? created;

  if (updated <= created) return created;

  const timeSinceUpdate = now - updated;
  const decay = Math.min(1, Math.max(0, timeSinceUpdate / DECAY_MS));
  return updated + (created - updated) * decay;
}

const sortedWorlds = worlds.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return getEffectiveDate(b) - getEffectiveDate(a);
});

const sortedAvatars = avatars.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.name.localeCompare(b.data.name);
});

const worldTags = [...new Set(worlds.flatMap(w => w.data.tags))].sort();
const avatarSeries = [...new Set(avatars.map(a => a.data.series))].sort();
---

<DesktopLayout>
  <DesktopShell>
    <!-- The "hack" — main expanded card -->
    <Fragment slot="main">
      <GlossyCard id="main-card" title=".hack//VRC" accent="accent">
        <Fragment slot="nav">
          <button class="subview-btn subview-active" data-subview="view-group">Group</button>
          <button class="subview-btn" data-subview="view-whatis">.hack?</button>
          <button class="subview-btn" data-subview="view-official">Official</button>
          <button class="subview-btn" data-subview="view-community">Community</button>
        </Fragment>
        <InfoCard />
      </GlossyCard>
    </Fragment>

    <!-- The "//" — slash cards -->
    <Fragment slot="slashes">
      <SlashCard id="database-slash" title="Database" accent="purple">
        <DatabaseCard worlds={sortedWorlds} avatars={sortedAvatars} worldTags={worldTags} avatarSeries={avatarSeries} />
      </SlashCard>

      <SlashCard id="community-slash" title="Community" accent="teal">
        <CommunityPanel />
      </SlashCard>
    </Fragment>
  </DesktopShell>
</DesktopLayout>

<!-- Controller: sub-views + card swapping -->
<script is:inline>
  (function () {
    // ---- Sub-view switching ----
    var subviewBtns = document.querySelectorAll('[data-subview]');
    var subviews = document.querySelectorAll('.subview');

    subviewBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-subview');
        subviewBtns.forEach(function (b) { b.classList.remove('subview-active'); });
        btn.classList.add('subview-active');
        subviews.forEach(function (sv) {
          sv.style.display = sv.id === target ? '' : 'none';
        });

      });
    });

    // ---- Timeline interaction ----
    var timelineNodes = document.querySelectorAll('.timeline-node');
    var timelineDetails = document.querySelectorAll('.timeline-detail');

    timelineNodes.forEach(function (node) {
      node.addEventListener('click', function () {
        var entry = node.getAttribute('data-entry');
        var target = document.getElementById('entry-' + entry);
        var isActive = node.classList.contains('timeline-active');

        // Deactivate all
        timelineNodes.forEach(function (n) { n.classList.remove('timeline-active'); });
        timelineDetails.forEach(function (d) { d.classList.remove('timeline-detail-active'); });

        // Toggle: if it was already active, just close it
        if (!isActive && target) {
          node.classList.add('timeline-active');
          target.classList.add('timeline-detail-active');
        }
      });
    });

    // ---- Gallery cycling ----
    var galleries = document.querySelectorAll('[data-gallery]');
    galleries.forEach(function (gallery) {
      var images = gallery.querySelectorAll('img');
      if (images.length < 2) return;

      var dots = gallery.querySelectorAll('.timeline-gallery-dot');
      var current = 0;
      images[0].classList.add('gallery-active');
      if (dots.length) dots[0].classList.add('gallery-dot-active');

      setInterval(function () {
        images[current].classList.remove('gallery-active');
        if (dots.length) dots[current].classList.remove('gallery-dot-active');
        current = (current + 1) % images.length;
        images[current].classList.add('gallery-active');
        if (dots.length) dots[current].classList.add('gallery-dot-active');
      }, 4000);
    });

    // ---- Subtle tilt on main card ----
    var tiltCard = document.querySelector('[data-card-role="main"]');
    var tiltInner = tiltCard ? tiltCard.querySelector('.main-card-inner') : null;
    var tiltMax = 2.5; // degrees
    var tiltSmooth = null;

    if (tiltCard && tiltInner && window.matchMedia('(pointer: fine)').matches) {
      tiltCard.addEventListener('mousemove', function (e) {
        if (tiltCard.classList.contains('main-collapsed')) return;
        var rect = tiltCard.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;  // -0.5 to 0.5
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        tiltInner.style.transform = 'perspective(800px) rotateY(' + (x * tiltMax) + 'deg) rotateX(' + (-y * tiltMax) + 'deg)';
      });

      tiltCard.addEventListener('mouseleave', function () {
        tiltInner.style.transform = '';
      });
    }

    // ---- Card expansion: expanded card always goes to order:1 (left) ----
    var mainCard = document.querySelector('[data-card-role="main"]');
    var mainTitle = mainCard.querySelector('.main-card-titlebar h2');
    var mainTitleOriginal = mainTitle ? mainTitle.textContent : '';
    var slashCards = document.querySelectorAll('[data-card-role="slash"]');
    var allCards = [mainCard].concat(Array.from(slashCards));
    var moduleBtns = document.querySelectorAll('[data-module]');
    var activeMainId = 'main-card';

    function updateModuleBar() {
      moduleBtns.forEach(function (btn) {
        var moduleId = btn.getAttribute('data-module');
        btn.classList.toggle('module-active', moduleId === activeMainId);
      });
    }

    function resetOrder() {
      // Default: main is order 1, slashes are order 2
      mainCard.style.order = '1';
      slashCards.forEach(function (s) {
        s.style.order = '2';
      });
    }

    function expandSlash(slashId) {
      var slash = document.getElementById(slashId);
      if (!slash || slash.classList.contains('slash-expanded')) return;

      // Collapse any expanded slash first
      slashCards.forEach(function (s) {
        s.classList.remove('slash-expanded');
        s.style.order = '2';
      });

      // Collapse main card and move it right
      mainCard.classList.add('main-collapsed');
      mainCard.style.order = '2';
      if (mainTitle) mainTitle.textContent = 'Home';

      // Expand this slash and move it left
      slash.classList.add('slash-expanded');
      slash.style.order = '1';

      activeMainId = slashId;
      updateModuleBar();
    }

    function restoreMain() {
      mainCard.classList.remove('main-collapsed');
      if (mainTitle) mainTitle.textContent = mainTitleOriginal;
      slashCards.forEach(function (s) {
        s.classList.remove('slash-expanded');
      });
      resetOrder();
      activeMainId = 'main-card';
      updateModuleBar();
    }

    // Click slash cards to expand
    slashCards.forEach(function (slash) {
      slash.addEventListener('click', function () {
        if (slash.classList.contains('slash-expanded')) return;
        expandSlash(slash.id);
      });
    });

    // Click collapsed main card to restore
    mainCard.addEventListener('click', function () {
      if (mainCard.classList.contains('main-collapsed')) {
        restoreMain();
      }
    });

    // Module bar buttons
    moduleBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var moduleId = btn.getAttribute('data-module');
        if (moduleId === 'main-card') {
          restoreMain();
        } else {
          expandSlash(moduleId);
        }
      });
    });

    // Hash-based deep linking
    function checkHash() {
      var hash = window.location.hash.replace('#', '');
      var mapping = { database: 'database-slash', community: 'community-slash', home: 'main-card' };
      if (hash && mapping[hash]) {
        if (mapping[hash] === 'main-card') {
          restoreMain();
        } else {
          expandSlash(mapping[hash]);
        }
      }
    }
    checkHash();
    window.addEventListener('hashchange', checkHash);

    resetOrder();
    updateModuleBar();
  })();
</script>
